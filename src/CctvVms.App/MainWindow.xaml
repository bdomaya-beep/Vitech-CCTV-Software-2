<Window x:Class="CctvVms.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:modules="clr-namespace:CctvVms.App.Views.Modules"
        xmlns:controls="clr-namespace:CctvVms.App.Views.Controls"
        mc:Ignorable="d"
        Title="Vitech VMS"
        Width="1600" Height="930"
        MinWidth="1280" MinHeight="760"
        Background="#080E18"
        WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Icon Sidebar -->
        <Border Grid.Column="0" Background="#07111F" BorderBrush="#0F2035" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Height="56" Margin="0,0,0,4">
                    <Border Width="38" Height="38" CornerRadius="9" Background="#00C48C"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="V" FontSize="19" FontWeight="Black" Foreground="#061018"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Border>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="4,0,4,0">

                    <Button Style="{StaticResource NavItemButtonStyle}"
                            Command="{Binding SwitchModuleCommand}" CommandParameter="LiveView">
                        <Button.Tag>
                            <Binding Path="ActiveModule" Converter="{StaticResource ModuleToAccentConverter}" ConverterParameter="LiveView" />
                        </Button.Tag>
                        <StackPanel>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Canvas.Left="2" Canvas.Top="3"  Width="9" Height="7" Fill="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Canvas.Left="13" Canvas.Top="3"  Width="9" Height="7" Fill="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Canvas.Left="2" Canvas.Top="12" Width="9" Height="7" Fill="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Canvas.Left="13" Canvas.Top="12" Width="9" Height="7" Fill="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" RadiusX="1" RadiusY="1"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Live" FontSize="9" HorizontalAlignment="Center"
                                       Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavItemButtonStyle}"
                            Command="{Binding SwitchModuleCommand}" CommandParameter="Playback">
                        <Button.Tag>
                            <Binding Path="ActiveModule" Converter="{StaticResource ModuleToAccentConverter}" ConverterParameter="Playback" />
                        </Button.Tag>
                        <StackPanel>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Polygon Points="7,4 20,12 7,20" Fill="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Play" FontSize="9" HorizontalAlignment="Center"
                                       Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavItemButtonStyle}"
                            Command="{Binding SwitchModuleCommand}" CommandParameter="DeviceManager">
                        <Button.Tag>
                            <Binding Path="ActiveModule" Converter="{StaticResource ModuleToAccentConverter}" ConverterParameter="DeviceManager" />
                        </Button.Tag>
                        <StackPanel>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Canvas.Left="8" Canvas.Top="2" Width="8" Height="8"
                                             Stroke="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent"/>
                                    <Path Data="M4,22 Q4,15 12,15 Q20,15 20,22"
                                          Stroke="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Devices" FontSize="9" HorizontalAlignment="Center"
                                       Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavItemButtonStyle}"
                            Command="{Binding SwitchModuleCommand}" CommandParameter="Settings">
                        <Button.Tag>
                            <Binding Path="ActiveModule" Converter="{StaticResource ModuleToAccentConverter}" ConverterParameter="Settings" />
                        </Button.Tag>
                        <StackPanel>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6"
                                             Stroke="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent"/>
                                    <Path Data="M12,2 L12,5 M12,19 L12,22 M2,12 L5,12 M19,12 L22,12 M4.9,4.9 L7,7 M17,17 L19.1,19.1 M19.1,4.9 L17,7 M7,17 L4.9,19.1"
                                          Stroke="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Settings" FontSize="9" HorizontalAlignment="Center"
                                       Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Camera Tree -->
        <Grid Grid.Column="1" Background="#07111F">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Tree Header -->
            <Border Background="#07111F" BorderBrush="#0F2035" BorderThickness="0,0,0,1" Padding="14,12">
                <Grid>
                    <TextBlock Text="CAMERAS" FontSize="10" FontWeight="Bold" Foreground="#4A6880"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource GhostButtonStyle}" Content="＋" Width="26" Height="26"
                                ToolTip="Add Device" Click="AddButton_OnTreeClick" />
                        <Button Style="{StaticResource GhostButtonStyle}" Content="⟳" Width="26" Height="26"
                                ToolTip="Discover" Click="DiscoverButton_OnTreeClick" Margin="4,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <modules:DeviceTreeControl Grid.Row="1" DataContext="{Binding DeviceTree}" />            <!-- Module Footer -->
            <Border Grid.Row="2" Background="#060E1A" BorderBrush="#0F2035" BorderThickness="0,1,0,0" Padding="10,8"
                    Visibility="{Binding HasSidebarFooter, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid Visibility="{Binding IsLiveViewModule, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Height="28"
                                  ItemsSource="{Binding LiveWorkspaces}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedLiveWorkspace}"
                                  VerticalAlignment="Center" />
                        <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Content="+" Width="28" Height="28"
                                Margin="4,0,0,0" ToolTip="New workspace" Command="{Binding CreateLiveWorkspaceCommand}" />
                        <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}" Content="?" Width="28" Height="28"
                                Margin="2,0,0,0" ToolTip="Remove workspace" Command="{Binding RemoveLiveWorkspaceCommand}" />
                    </Grid>

                    <Border Visibility="{Binding IsPlaybackModule, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#0B1524" BorderBrush="#1B314D" BorderThickness="1" CornerRadius="8" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="Playback Settings" FontSize="11" FontWeight="SemiBold" Foreground="#7F9BB6" />
                            <TextBlock Margin="0,4,0,8"
                                       Text="{Binding Playback.SelectedCamera.Name, TargetNullValue=Select a camera from Cameras}"
                                       Foreground="#000000"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="Record Type" Foreground="#7F9BB6" FontSize="11" Margin="0,0,0,4" />
                                    <ComboBox Height="28" SelectedIndex="0" Background="#162339" Foreground="#000000" BorderBrush="#24334A">
                                        <ComboBoxItem Content="All Records" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Stream Type" Foreground="#7F9BB6" FontSize="11" Margin="0,0,0,4" />
                                    <ComboBox Height="28" SelectedIndex="0" Background="#162339" Foreground="#000000" BorderBrush="#24334A">
                                        <ComboBoxItem Content="Main Stream" />
                                        <ComboBoxItem Content="Sub Stream" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <controls:DarkDatePicker SelectedDate="{Binding Playback.SelectedDate, Mode=TwoWay}" Margin="0,0,0,8" />
                            <Border Background="#0B1524" BorderBrush="#1B314D" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,0,0,8">
                                <DockPanel>
                                    <TextBlock Text="Selected Time" Foreground="#7F9BB6" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Playback.TimelinePosition, Converter={StaticResource SecondsToClockConverter}}"
                                               Foreground="#E6F2FF"
                                               FontWeight="SemiBold" />
                                </DockPanel>
                            </Border>
                            <DockPanel LastChildFill="False">
                                <Button DockPanel.Dock="Left" Content="-30s" Width="54" Height="28" Margin="0,0,6,0"
                                        Style="{StaticResource GhostButtonStyle}" Command="{Binding Playback.RewindCommand}" />
                                <Button DockPanel.Dock="Left" Content="Pause" Width="58" Height="28" Margin="0,0,6,0"
                                        Style="{StaticResource LayoutButtonStyle}" Command="{Binding Playback.PauseCommand}" />
                                <Button DockPanel.Dock="Right" Content="Search" Width="82" Height="30"
                                        Style="{StaticResource AccentButtonStyle}" Command="{Binding Playback.PlayCommand}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Background="#07111F" BorderBrush="#0F2035" BorderThickness="0,0,0,1" Padding="14,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveModuleTitle}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#C8DDEF" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#00C48C" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SystemStatusText}" Foreground="#4A6880" FontSize="11"
                                   VerticalAlignment="Center" />
                        <Button Content="⤢ Detach" Style="{StaticResource GhostButtonStyle}" Height="26"
                                Padding="8,0" Margin="16,0,0,0" Click="DetachLiveView_OnClick" />
                        <Button Content="+ New Live" Style="{StaticResource GhostButtonStyle}" Height="26"
                                Padding="8,0" Margin="8,0,0,0" Click="NewLiveView_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- All module controls pre-instantiated — no destroy/recreate on page switch -->
            <Grid Grid.Row="1">
                <modules:LiveViewControl    x:Name="LiveViewPage"      DataContext="{Binding LiveView}" />
                <modules:PlaybackControl    x:Name="PlaybackPage"      DataContext="{Binding Playback}"       Visibility="Collapsed" Opacity="0" />
                <modules:DeviceManagerControl x:Name="DeviceManagerPage" DataContext="{Binding DeviceManager}" Visibility="Collapsed" Opacity="0" />
                <modules:SettingsControl    x:Name="SettingsPage"      DataContext="{Binding Settings}"      Visibility="Collapsed" Opacity="0" />
            </Grid>
        </Grid>
    </Grid>
</Window>