<Window x:Class="CctvVms.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:modules="clr-namespace:CctvVms.App.Views.Modules"
        mc:Ignorable="d"
        Title="CCTV VMS Control Center"
        Width="1600"
        Height="930"
        MinWidth="1280"
        MinHeight="760"
        Background="#0A111D">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="290" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#0F1A2D" BorderBrush="#1F2E45" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="VMS" FontSize="21" FontWeight="Bold" Foreground="#12B886" Margin="0,0,18,0" />
                    <Button Content="Live View" Width="120" Height="34" Margin="0,0,8,0" Command="{Binding SwitchModuleCommand}" CommandParameter="LiveView" />
                    <Button Content="Playback" Width="120" Height="34" Margin="0,0,8,0" Command="{Binding SwitchModuleCommand}" CommandParameter="Playback" />
                    <Button Content="Device Manager" Width="140" Height="34" Margin="0,0,8,0" Command="{Binding SwitchModuleCommand}" CommandParameter="DeviceManager" />
                    <Button Content="Settings" Width="110" Height="34" Command="{Binding SwitchModuleCommand}" CommandParameter="Settings" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SystemStatusText}" Foreground="#A2BAD8" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="8" Background="#101826" BorderBrush="#24334A" BorderThickness="1" CornerRadius="6">
            <modules:DeviceTreeControl DataContext="{Binding DeviceTree}" />
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="0,8,0,8" Background="#0C1424" BorderBrush="#24334A" BorderThickness="1" CornerRadius="6">
            <ContentControl Content="{Binding CurrentModuleViewModel}" />
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Margin="8" Background="#101826" BorderBrush="#24334A" BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel>
                <TextBlock Text="Stream Inspector" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12" />
                <TextBlock Text="Camera" Foreground="#9BB1CC" FontSize="11" />
                <TextBlock Text="{Binding SelectedCameraName}" Margin="0,0,0,10" />
                <TextBlock Text="Status" Foreground="#9BB1CC" FontSize="11" />
                <TextBlock Text="{Binding SelectedCameraStatus}" Margin="0,0,0,10" />
                <TextBlock Text="Bitrate" Foreground="#9BB1CC" FontSize="11" />
                <TextBlock Text="{Binding SelectedCameraBitrate}" Margin="0,0,0,10" />
                <TextBlock Text="Resolution" Foreground="#9BB1CC" FontSize="11" />
                <TextBlock Text="{Binding SelectedCameraResolution}" Margin="0,0,0,10" />
                <TextBlock Text="FPS" Foreground="#9BB1CC" FontSize="11" />
                <TextBlock Text="{Binding SelectedCameraFps}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
