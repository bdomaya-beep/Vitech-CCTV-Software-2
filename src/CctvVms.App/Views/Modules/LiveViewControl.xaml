<UserControl x:Class="CctvVms.App.Views.Modules.LiveViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="12,12,12,8">
            <Button Content="1x1" Width="56" Margin="0,0,6,0" Command="{Binding SetLayoutCommand}" CommandParameter="1x1" />
            <Button Content="2x2" Width="56" Margin="0,0,6,0" Command="{Binding SetLayoutCommand}" CommandParameter="2x2" />
            <Button Content="3x3" Width="56" Margin="0,0,6,0" Command="{Binding SetLayoutCommand}" CommandParameter="3x3" />
            <Button Content="4x4" Width="56" Margin="0,0,6,0" Command="{Binding SetLayoutCommand}" CommandParameter="4x4" />
            <TextBlock VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#8FA9CA" Text="Drag cameras from left panel into any tile" />
        </StackPanel>

        <ItemsControl x:Name="TilesItemsControl"
              Grid.Row="1"
              ItemsSource="{Binding Tiles}"
              Margin="12,0,12,12"
              Visibility="{Binding IsZoomedIn, Converter={StaticResource BoolToInverseVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="{Binding Rows}" Columns="{Binding Columns}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="3" BorderBrush="#2A3B55" BorderThickness="1" CornerRadius="4" Background="#0B1321" AllowDrop="True" Drop="Tile_OnDrop" PreviewMouseLeftButtonDown="Tile_OnPreviewMouseLeftButtonDown" MouseLeftButtonDown="Tile_OnMouseLeftButtonDown">
                        <Grid Tag="{Binding TileId}">
                            <vlc:VideoView x:Name="TileVideo"
                                           MediaPlayer="{Binding MediaPlayer}"
                                           Visibility="{Binding CameraId, Converter={StaticResource StringToVisibilityConverter}}"
                                           IsHitTestVisible="False" />
                            <Border x:Name="EmptyOverlay" Background="#1E2A3A" Visibility="{Binding CameraId, Converter={StaticResource StringToInverseVisibilityConverter}}">
                                <TextBlock Text="Drop Camera" Foreground="#7F97B8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <Border Background="#AA07111D" Visibility="{Binding IsDeploying, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Deploying stream..." Foreground="#9FD8C6" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#8808111D" Height="24" VerticalAlignment="Top">
                                <DockPanel Margin="8,0">
                                    <TextBlock Text="{Binding CameraName}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StreamTypeText}" Margin="8,0,0,0" Foreground="#74D9BD" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding CameraStatusText}" Margin="8,0,0,0" Foreground="#9BB1CC" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,0,6,6">
                                <Button Content="Focus" Width="56" Height="24" Margin="0,0,4,0" IsEnabled="{Binding IsDeploying, Converter={StaticResource BoolToInverseVisibilityConverter}}" Command="{Binding DataContext.FocusTileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                                <Button Content="Clear" Width="56" Height="24" IsEnabled="{Binding IsDeploying, Converter={StaticResource BoolToInverseVisibilityConverter}}" Command="{Binding DataContext.ClearTileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

          <Grid Grid.Row="1"
              Panel.ZIndex="20"
              Background="#050A10CC"
              Visibility="{Binding IsZoomedIn, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12" Background="#111C2E">
                <TextBlock Foreground="#9BB1CC" VerticalAlignment="Center" Margin="8,6,12,6" Text="Press Escape or click Exit to return to grid" />
                <Button Content="Exit Zoom" Width="80" Margin="0,6,8,6" Command="{Binding ExitZoomCommand}" />
            </StackPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding ZoomTiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0" BorderBrush="#2A3B55" BorderThickness="0" Background="#0B1321">
                            <vlc:VideoView MediaPlayer="{Binding MediaPlayer}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
