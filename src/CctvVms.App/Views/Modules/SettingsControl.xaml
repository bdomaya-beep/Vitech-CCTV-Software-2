<UserControl x:Class="CctvVms.App.Views.Modules.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Max Main Streams" VerticalAlignment="Center" />
        <TextBox Grid.Column="1" Text="{Binding MaxMainStreams}" Margin="8,0,0,12" />

        <TextBlock Grid.Row="1" Text="Max Active Decoders" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxActiveDecoders}" Margin="8,0,0,12" />

        <Button Grid.Row="2" Grid.Column="1" Width="120" Height="32" HorizontalAlignment="Left" Content="Save Settings" Command="{Binding SaveCommand}" />
    </Grid>
</UserControl>
