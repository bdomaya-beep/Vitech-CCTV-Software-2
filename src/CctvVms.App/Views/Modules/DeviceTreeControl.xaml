<UserControl x:Class="CctvVms.App.Views.Modules.DeviceTreeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:CctvVms.App.ViewModels"
             mc:Ignorable="d">
    <TreeView ItemsSource="{Binding RootNodes}"
              SelectedItemChanged="TreeView_OnSelectedItemChanged"
              PreviewMouseMove="TreeView_OnPreviewMouseMove"
              MouseDoubleClick="TreeView_OnMouseDoubleClick"
              Background="Transparent"
              BorderThickness="0"
              Padding="6,4"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling"
              ScrollViewer.CanContentScroll="True">

        <!-- Override system selection highlight colors for the whole tree -->
        <TreeView.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"         Color="#0D2540" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"     Color="#FFFFFF" />
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#0A1A2E" />
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#C8DDEF" />

            <HierarchicalDataTemplate DataType="{x:Type viewModels:DeviceTreeNodeViewModel}"
                                      ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,8,0"
                             Fill="{Binding StatusText, Converter={StaticResource StatusToColorConverter}}" />
                    <!-- No hardcoded Foreground — inherits from TreeViewItem so selection color works -->
                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </HierarchicalDataTemplate>
        </TreeView.Resources>

        <TreeView.ItemContainerStyle>
            <Style TargetType="TreeViewItem">
                <Setter Property="Foreground" Value="#A8C0D8" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Padding" Value="4,0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TreeViewItem">
                            <StackPanel>
                                <!-- Row -->
                                <Border x:Name="RowBg"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="3"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="0,1,0,1">
                                    <DockPanel>
                                        <!-- Expander toggle -->
                                        <ToggleButton x:Name="Expander"
                                                      DockPanel.Dock="Left"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                      Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      Width="14" Height="14"
                                                      Margin="0,0,4,0"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Cursor="Hand"
                                                      Focusable="False">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <TextBlock x:Name="Arrow" Text="▶"
                                                               FontSize="8" Foreground="#2E4A63"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Arrow" Property="Text" Value="▼" />
                                                            <Setter TargetName="Arrow" Property="Foreground" Value="#4A6880" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <!-- Spacer when no expander -->
                                        <Border Width="18" DockPanel.Dock="Left"
                                                Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToInverseVisibilityConverter}}" />
                                        <!-- Content -->
                                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>
                                <!-- Children -->
                                <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" Visibility="Collapsed" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsExpanded" Value="True">
                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RowBg" Property="Background" Value="#0C1E30" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="RowBg" Property="Background" Value="#0D2540" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True" />
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="RowBg" Property="Background" Value="#102E50" />
                                </MultiTrigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TreeView.ItemContainerStyle>

        <TreeView.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Add device"    Command="{Binding AddDeviceCommand}" />
                <MenuItem Header="Edit device"   Command="{Binding EditSelectedCommand}" />
                <MenuItem Header="Delete device" Command="{Binding DeleteSelectedCommand}" />
            </ContextMenu>
        </TreeView.ContextMenu>
    </TreeView>
</UserControl>

