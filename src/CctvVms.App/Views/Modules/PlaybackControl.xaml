<UserControl x:Class="CctvVms.App.Views.Modules.PlaybackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:CctvVms.App.Views.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="#080E18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#07111F" BorderBrush="#0F2035" BorderThickness="0,0,0,1" Padding="16,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="PLAYBACK" FontSize="10" FontWeight="Bold" Foreground="#2E4A63" />
                    <TextBlock Text="Recorded Video Review" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <TextBlock Text="Choose a camera, jump to a day, and scrub to the moment you want to inspect." Foreground="#7F95B3" Margin="0,4,0,0" />
                </StackPanel>

                <Border DockPanel.Dock="Right" Background="#0C1A2A" BorderBrush="#17304E" BorderThickness="1" CornerRadius="14" Padding="12,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#12B886" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding PlaybackState}" Foreground="#C8DDEF" FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16,16,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0B1321" BorderBrush="#0F2035" BorderThickness="1" CornerRadius="8" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="SESSION" FontSize="10" FontWeight="Bold" Foreground="#2E4A63" />
                        <TextBlock Text="Review Controls" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />

                        <TextBlock Text="Camera" Foreground="#7F95B3" Margin="0,18,0,6" />
                        <ComboBox ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}" DisplayMemberPath="Name" MinHeight="34" />

                        <TextBlock Text="Recording Day" Foreground="#7F95B3" Margin="0,14,0,6" />
                        <DatePicker SelectedDate="{Binding SelectedDate}" MinHeight="34" />

                        <Border Margin="0,18,0,0" Padding="14" Background="#0E1A2C" BorderBrush="#15304D" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Target Time" Foreground="#7F95B3" FontSize="11" />
                                <TextBlock Text="{Binding TimelinePosition, Converter={StaticResource SecondsToClockConverter}}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SelectedDate, StringFormat={}{0:dddd, dd MMM yyyy}}" Foreground="#9BB1CC" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <UniformGrid Columns="2" Margin="0,16,0,0">
                            <Border Margin="0,0,6,0" Padding="12" Background="#09111E" BorderBrush="#0F2035" BorderThickness="1" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="Selected Camera" Foreground="#6E87A5" FontSize="10" />
                                    <TextBlock Text="{Binding SelectedCamera.Name, TargetNullValue=No camera selected}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Margin="6,0,0,0" Padding="12" Background="#09111E" BorderBrush="#0F2035" BorderThickness="1" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="Playback Source" Foreground="#6E87A5" FontSize="10" />
                                    <TextBlock Text="Recorded clips" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Margin="0,16,0,0" Padding="14" Background="#07111F" BorderBrush="#0F2035" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="How It Works" FontSize="11" FontWeight="Bold" Foreground="#2E4A63" />
                                <TextBlock Text="Playback now follows the selected day and timeline. If there is no matching recording, the page will tell you directly instead of opening a live feed." TextWrapping="Wrap" Foreground="#9BB1CC" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#0B1321" BorderBrush="#0F2035" BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="4,2,4,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="VIDEO STAGE" FontSize="10" FontWeight="Bold" Foreground="#2E4A63" />
                            <TextBlock Text="{Binding SelectedCamera.Name, TargetNullValue=No camera selected}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>

                        <Border DockPanel.Dock="Right" Background="#0C1A2A" BorderBrush="#17304E" BorderThickness="1" CornerRadius="14" Padding="10,5" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TimelinePosition, Converter={StaticResource SecondsToClockConverter}}" Foreground="#C8DDEF" FontWeight="SemiBold" />
                        </Border>
                    </DockPanel>

                    <Border Grid.Row="1" BorderBrush="#1A2F4A" BorderThickness="1" CornerRadius="8" Background="#050A14" ClipToBounds="True">
                        <Grid>
                            <controls:VideoTileControl VideoSource="{Binding PlaybackSource}" />

                            <Border Visibility="{Binding PlaybackSource, Converter={StaticResource NullToVisibilityConverter}}" Background="#D9050A14">
                                <Grid>
                                    <Border Width="420" Padding="24" Background="#0C1626" BorderBrush="#17304E" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel>
                                            <Border Width="54" Height="54" CornerRadius="27" Background="#10233A" HorizontalAlignment="Left">
                                                <TextBlock Text="Play" Foreground="#12B886" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Playback Ready" FontSize="24" FontWeight="SemiBold" Margin="0,16,0,0" />
                                            <TextBlock Text="{Binding PlaybackState}" Foreground="#9BB1CC" TextWrapping="Wrap" Margin="0,8,0,0" />
                                            <TextBlock Text="Pick a recorded day and press Play. If clips exist for that camera and time, they will open here." Foreground="#7F95B3" TextWrapping="Wrap" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border VerticalAlignment="Top" HorizontalAlignment="Stretch" Height="56" Visibility="{Binding PlaybackSource, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#D9000000" Offset="0" />
                                        <GradientStop Color="#00000000" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <DockPanel Margin="14,10,14,0">
                                    <TextBlock Text="Recorded Playback" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedDate, StringFormat={}{0:dd MMM yyyy}}" Foreground="#9BB1CC" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#07111F" BorderBrush="#0F2035" BorderThickness="0,1,0,0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock Text="Timeline" FontSize="11" FontWeight="Bold" Foreground="#2E4A63" />
                    <TextBlock DockPanel.Dock="Right" Text="{Binding TimelinePosition, Converter={StaticResource SecondsToClockConverter}}" Foreground="#C8DDEF" FontSize="12" FontWeight="SemiBold" />
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Slider Minimum="0" Maximum="86400" Value="{Binding TimelinePosition}" TickFrequency="1800" IsSnapToTickEnabled="False" />
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="00:00:00" Foreground="#5E7897" />
                        <TextBlock DockPanel.Dock="Right" Text="24:00:00" Foreground="#5E7897" />
                    </DockPanel>

                    <DockPanel Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button Content="Play" Style="{StaticResource AccentButtonStyle}" Width="82" Height="32" Margin="0,0,8,0" Command="{Binding PlayCommand}" />
                            <Button Content="Pause" Style="{StaticResource LayoutButtonStyle}" Width="82" Margin="0,0,8,0" Command="{Binding PauseCommand}" />
                            <Button Content="-30s" Style="{StaticResource GhostButtonStyle}" Padding="12,6" Margin="0,0,6,0" Command="{Binding RewindCommand}" />
                            <Button Content="+30s" Style="{StaticResource GhostButtonStyle}" Padding="12,6" Command="{Binding FastForwardCommand}" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Review Point" Foreground="#5E7897" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <Border Background="#0C1A2A" BorderBrush="#17304E" BorderThickness="1" CornerRadius="14" Padding="10,5">
                                <TextBlock Text="{Binding TimelinePosition, Converter={StaticResource SecondsToClockConverter}}" Foreground="#C8DDEF" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
