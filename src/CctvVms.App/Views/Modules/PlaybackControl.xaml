<UserControl x:Class="CctvVms.App.Views.Modules.PlaybackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:CctvVms.App.Views.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Circular transport button style -->
        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="#C8D8EC" />
            <Setter Property="Background" Value="#1E2C3D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="19"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A3D55" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12B886" />
                                <Setter Property="Foreground" Value="#061018" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large play button -->
        <Style x:Key="TransportPlayButtonStyle" TargetType="Button" BasedOn="{StaticResource TransportButtonStyle}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="#12B886" />
            <Setter Property="Foreground" Value="#061018" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="24"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1CD4A2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0E9A70" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#12171D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#12171D" Padding="18,16,18,12" BorderBrush="#26303A" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Playback" Foreground="#F2F7FF" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#8FA0B3"
                               Text="Choose a camera from the Cameras panel, then use the playback settings below it." />
                </StackPanel>

                <Border Grid.Column="1" Margin="16,0,12,0" Padding="12,8" Background="#1A2129" BorderBrush="#2D3742" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Current Camera" Foreground="#7E8D9E" FontSize="11" />
                        <TextBlock Text="{Binding SelectedCamera.Name, TargetNullValue=None}"
                                   Foreground="#E8F0FB" FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="12,8" Background="#1A2129" BorderBrush="#2D3742" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Cursor Time" Foreground="#7E8D9E" FontSize="11" />
                        <TextBlock Text="{Binding TimelinePosition, Converter={StaticResource SecondsToClockConverter}}"
                                   Foreground="#E8F0FB" FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Video viewer -->
        <Border Grid.Row="1" Margin="18,16,18,14" Background="#171D24" BorderBrush="#29323C" BorderThickness="1" CornerRadius="12">
            <Grid>
                <controls:VideoTileControl VideoSource="{Binding PlaybackSource}" />
                <Border Visibility="{Binding PlaybackSource, Converter={StaticResource NullToVisibilityConverter}}" Background="#D6171D24" CornerRadius="12">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="440">
                        <TextBlock Text="No playback loaded" Foreground="#F2F7FF" FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Margin="0,10,0,0" Text="{Binding PlaybackState}" Foreground="#A7B7C8" TextAlignment="Center" HorizontalAlignment="Center" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="Select a camera from the Cameras panel on the left, adjust playback settings below it, then press Search."
                                   Foreground="#7E91A4" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Timeline + Transport controls -->
        <Border Grid.Row="2" Margin="15,0,15,15" Background="#1A2027" BorderBrush="#29323C" BorderThickness="1" CornerRadius="12" Padding="16,14,16,16">
            <StackPanel>

                <!-- Zoomable timeline -->
                <controls:ZoomableTimelineControl
                        Position="{Binding TimelinePosition, Mode=TwoWay}"
                        SeekCommand="{Binding SeekCommand}"
                        Margin="0,0,0,12"
                        ToolTip="Scroll to zoom | Drag to pan | Click to seek" />

                <!-- Transport controls - centered -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: status badge -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Border Background="#10161C" BorderBrush="#27313C" BorderThickness="1" CornerRadius="12" Padding="10,4">
                            <TextBlock Text="{Binding PlaybackState}" Foreground="#EAF2FA" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>

                    <!-- Center: circular transport buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Skip to start -->
                        <Button Style="{StaticResource TransportButtonStyle}"
                                ToolTip="Skip to start"
                                Command="{Binding RewindCommand}"
                                Content="&#x23EE;" />
                        <!-- Rewind 30s -->
                        <Button Style="{StaticResource TransportButtonStyle}"
                                ToolTip="Rewind 30s"
                                Command="{Binding RewindCommand}"
                                Content="&#x23EA;" />
                        <!-- Play -->
                        <Button Style="{StaticResource TransportPlayButtonStyle}"
                                ToolTip="Play"
                                Command="{Binding PlayCommand}"
                                Content="&#x25B6;" />
                        <!-- Pause -->
                        <Button Style="{StaticResource TransportButtonStyle}"
                                ToolTip="Pause"
                                Command="{Binding PauseCommand}"
                                Content="&#x23F8;" />
                        <!-- Forward 30s -->
                        <Button Style="{StaticResource TransportButtonStyle}"
                                ToolTip="Forward 30s"
                                Command="{Binding FastForwardCommand}"
                                Content="&#x23E9;" />
                        <!-- Skip to end -->
                        <Button Style="{StaticResource TransportButtonStyle}"
                                ToolTip="Skip to end"
                                Command="{Binding FastForwardCommand}"
                                Content="&#x23ED;" />
                    </StackPanel>

                    <!-- Right: current time -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="&#x23F1; " Foreground="#718193" FontSize="12" VerticalAlignment="Center" />
                        <Border Background="#10161C" BorderBrush="#27313C" BorderThickness="1" CornerRadius="12" Padding="10,4">
                            <TextBlock Text="{Binding TimelinePosition, Converter={StaticResource SecondsToClockConverter}}"
                                       Foreground="#12B886" FontSize="13" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
