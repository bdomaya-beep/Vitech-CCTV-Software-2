<UserControl x:Class="CctvVms.App.Views.Modules.PlaybackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Camera" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Width="220" ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}" DisplayMemberPath="Name" />
            <DatePicker SelectedDate="{Binding SelectedDate}" Margin="10,0,0,0" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#2A3B55" BorderThickness="1" CornerRadius="4" Background="#0B1321">
            <vlc:VideoView MediaPlayer="{Binding PlaybackPlayer}" />
        </Border>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <Slider Minimum="0" Maximum="86400" Value="{Binding TimelinePosition}" />
            <DockPanel Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Play" Width="68" Margin="0,0,6,0" Command="{Binding PlayCommand}" />
                    <Button Content="Pause" Width="68" Margin="0,0,6,0" Command="{Binding PauseCommand}" />
                    <Button Content="+30s" Width="68" Margin="0,0,6,0" Command="{Binding FastForwardCommand}" />
                    <Button Content="-30s" Width="68" Command="{Binding RewindCommand}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding PlaybackState}" Foreground="#9BB1CC" />
            </DockPanel>
        </StackPanel>
    </Grid>
</UserControl>
