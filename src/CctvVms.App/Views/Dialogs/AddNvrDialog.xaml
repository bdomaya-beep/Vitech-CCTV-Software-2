<Window x:Class="CctvVms.App.Views.Dialogs.AddNvrDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add NVR Device" Width="560" Height="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#0C1424">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Device Name" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="8,0,0,10" />
        <TextBlock Grid.Row="0" Grid.Column="3" Text="NVR Type" VerticalAlignment="Center" />
        <ComboBox Grid.Row="0" Grid.Column="4" x:Name="NvrTypeBox" Margin="8,0,0,10" SelectedIndex="0" SelectionChanged="NvrTypeBox_SelectionChanged">
            <ComboBoxItem Content="Dahua" />
            <ComboBoxItem Content="Hikvision" />
            <ComboBoxItem Content="Generic" />
        </ComboBox>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="IP/Domain Name" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="IpBox" Margin="8,0,0,10" Text="192.168.1.100" />
        <TextBlock Grid.Row="1" Grid.Column="3" Text="Port No." VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="4" x:Name="DevicePortBox" Margin="8,0,0,10" Text="37777" />
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Username" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="UserBox" Margin="8,0,0,10" Text="admin" />
        <TextBlock Grid.Row="2" Grid.Column="3" Text="Password" VerticalAlignment="Center" />
        <PasswordBox Grid.Row="2" Grid.Column="4" x:Name="PasswordBox" Margin="8,0,0,10" />
        <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP Port" VerticalAlignment="Center" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="RtspPortBox" Margin="8,0,0,10" Text="554" />
        <TextBlock Grid.Row="3" Grid.Column="3" Text="Max Channels" VerticalAlignment="Center" />
        <TextBox Grid.Row="3" Grid.Column="4" x:Name="ChannelCountBox" Margin="8,0,0,10" Text="32" />
        <Border Grid.Row="4" Grid.ColumnSpan="5" Margin="0,10,0,0" Padding="10" Background="#111C2E" BorderBrush="#24334A" BorderThickness="1">
            <TextBlock x:Name="HintText" Foreground="#9BB1CC" TextWrapping="Wrap" Text="Dahua: port 37777. Hikvision: port 8000. RTSP streams are built from the NVR IP and channel number." />
        </Border>
        <StackPanel Grid.Row="5" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="90" Margin="0,0,8,0" Content="Cancel" Click="Cancel_OnClick" />
            <Button Width="90" Content="Add" Click="Connect_OnClick" />
        </StackPanel>
    </Grid>
</Window>