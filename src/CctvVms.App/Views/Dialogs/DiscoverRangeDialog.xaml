<Window x:Class="CctvVms.App.Views.Dialogs.DiscoverRangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discover NVRs"
        Width="390"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0C1424">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Gateway / Range" />
        <TextBox Grid.Row="1" x:Name="RangeBox" Margin="0,6,0,8" Text="192.168.1.1,192.168.100.1" />
        <TextBlock Grid.Row="2" Foreground="#9BB1CC" TextWrapping="Wrap" Text="Examples: 192.168.1.1,192.168.100.1 or 192.168.1.0/24,192.168.100.0/24" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="90" Margin="0,0,8,0" Content="Cancel" Click="Cancel_OnClick" />
            <Button Width="90" Content="Scan" Click="Scan_OnClick" />
        </StackPanel>
    </Grid>
</Window>
